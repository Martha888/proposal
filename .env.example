# Text model for menu and opportunity analysis.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=

# Image generation. For an OpenAI-compatible gateway, keep IMAGE_BACKEND=openai
# and set OPENAI_MODEL to the image-generation model.
IMAGE_BACKEND=openai
OPENAI_MODEL=

# Optional: lower concurrency can be more stable for some gateways.
IMAGE_CONCURRENCY=1

# Optional proxy settings. Leave empty unless your network requires them.
HTTP_PROXY=
HTTPS_PROXY=
